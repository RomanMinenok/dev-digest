{
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/engineering-insights-stop.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/engineering-insights-read.sh\""
          }
        ]
      }
    ]
  }
}
